SECRET_KEY=your-secret-key-here
DEBUG=True
DB_NAME=milkman_db
DB_USER=postgres
DB_PASSWORD=password
DB_HOST=localhost
DB_PORT=5432

# PayPal gateway configuration
# Create app credentials from https://developer.paypal.com/
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-client-secret
PAYPAL_MODE=sandbox
PAYPAL_CURRENCY=USD
PAYPAL_TIMEOUT_MINUTES=5

# Frontend URL used by PayPal return/cancel redirects
FRONTEND_BASE_URL=http://localhost:5173

# Email verification settings
EMAIL_VERIFICATION_EXPIRY_MINUTES=30
PASSWORD_RESET_EXPIRY_MINUTES=30
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=Sahil Milkman <noreply@milkman.local>
