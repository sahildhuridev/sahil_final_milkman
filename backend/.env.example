SECRET_KEY=your-secret-key-here
DEBUG=True
DB_NAME=milkman_db
DB_USER=postgres
DB_PASSWORD=password
DB_HOST=localhost
DB_PORT=5432

# PayPal gateway configuration
# Create app credentials from https://developer.paypal.com/
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-client-secret
PAYPAL_MODE=sandbox
PAYPAL_CURRENCY=USD
PAYPAL_TIMEOUT_MINUTES=5

# Frontend URL used by PayPal return/cancel redirects
FRONTEND_BASE_URL=http://localhost:5173
